{
  "name": "verticut",
  "version": "1.6.0",
  "description": "9:16 Vertical Gaming Video Editor",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "download-whisper": "node scripts/download-whisper.js",
    "build": "electron-builder --win portable",
    "build-installer": "electron-builder --win nsis",
    "publish": "electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.verticut.editor",
    "productName": "VertiCut",
    "copyright": "VertiCut",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server/**",
      "static/**"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "static/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "Sirsyorrz",
      "repo": "verticut"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "static/icon.ico",
      "deleteAppDataOnUninstall": false
    }
  }
}
